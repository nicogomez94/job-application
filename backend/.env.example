# Database
DATABASE_URL="postgresql://usuario:password@localhost:5432/job_platform?schema=public"

# JWT
JWT_SECRET="tu_secreto_jwt_super_seguro_cambiar_en_produccion"
JWT_EXPIRES_IN="7d"
RESET_PASSWORD_SECRET="tu_secreto_para_reset_password"
RESET_PASSWORD_TOKEN_EXPIRES_IN="30m"

# Google OAuth
GOOGLE_CLIENT_ID="tu_google_client_id"
GOOGLE_CLIENT_SECRET="tu_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="tu_access_token_de_mercado_pago"
MERCADO_PAGO_PUBLIC_KEY="tu_public_key_de_mercado_pago"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Email (SMTP real). Si no configurás estas variables en desarrollo, se usa Ethereal de prueba.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="professionals at home <no-reply@professionalsathome.com>"

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH="./uploads"
